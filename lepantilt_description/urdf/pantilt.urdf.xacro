<?xml version="1.0"?>
<robot name="lepantilt" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find lepantilt_description)/urdf/pantilt.common.xacro"/>
  <xacro:include filename="$(find lepantilt_description)/urdf/pantilt.control.xacro"/>

  <!-- Arguments (externally settable, default to property values in pantilt.control.xacro) -->
  <xacro:arg name="serial_port"    default="${serial_port}"/>
  <xacro:arg name="use_mock"       default="${use_mock}"/>
  <xacro:arg name="use_sync_write" default="${use_sync_write}"/>
  <xacro:arg name="tilt"           default="s2"/>
  <xacro:property name="tilt" value="tilt_joint_$(arg tilt)"/>

  <material name="light_grey">
    <color rgba="${light_grey_rgba}"/>
  </material>
  <material name="charcoal">
    <color rgba="${charcoal_rgba}"/>
  </material>

  <!-- LINKS -->

  <!-- Pantilt base link -->
  <link name="pantilt_base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${pantilt_offset_rz}"/>
      <geometry>
        <mesh filename="package://lepantilt_description/meshes/pantilt_base.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${pantilt_offset_rz}"/>
      <geometry>
        <mesh filename="package://lepantilt_description/meshes/pan_motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 ${pantilt_offset_rz}"/>
      <geometry>
        <mesh filename="package://lepantilt_description/meshes/pantilt_base.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Pan link -->
  <link name="pan_link">
    <inertial>
      <mass value="0.119226"/>
      <origin xyz="-9.07886e-05 0.0590972 0.031089" rpy="0 0 0"/>
      <inertia ixx="5.94278e-05" ixy="0" ixz="0" iyy="5.89975e-05" iyz="0" izz="3.13712e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="${pan_offset_rx} 0 ${pan_offset_rz}"/>
      <geometry>
        <mesh filename="package://lepantilt_description/meshes/pan_joint.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="${pan_offset_rx} 0 ${pan_offset_rz}"/>
      <geometry>
        <mesh filename="package://lepantilt_description/meshes/tilt_motor.stl"/>
      </geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pan_offset_rx} 0 ${pan_offset_rz}"/>
      <geometry>
        <mesh filename="package://lepantilt_description/meshes/pan_joint.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Tilt link -->
  <link name="tilt_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="${tilt_visual_x} ${tilt_visual_y} ${tilt_visual_z}" rpy="${tilt_offset_rx} ${tilt_offset_ry} 0"/>
      <geometry>
        <mesh filename="package://lepantilt_description/meshes/${tilt}.stl"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="${tilt_visual_x} ${tilt_visual_y} ${tilt_visual_z}" rpy="${tilt_offset_rx} ${tilt_offset_ry} 0"/>
      <geometry>
        <mesh filename="package://lepantilt_description/meshes/${tilt}.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- JOINTS -->

  <!-- Pan joint (revolute) -->
  <joint name="pan_joint" type="revolute">
    <parent link="pantilt_base_link"/>
    <child link="pan_link"/>
    <origin xyz="${pan_joint_x} 0 ${pan_joint_z}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${pan_joint_lower}" upper="${pan_joint_upper}" effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <!-- Tilt joint (revolute) -->
  <joint name="tilt_joint" type="revolute">
    <parent link="pan_link"/>
    <child link="tilt_link"/>
    <origin xyz="${tilt_joint_x} 0 ${tilt_joint_z}" rpy="${tilt_joint_rx} ${tilt_joint_ry} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${tilt_joint_lower}" upper="${tilt_joint_upper}" effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
  </joint>

  <!-- ROS 2 CONTROL -->
  <ros2_control name="lepantilt_control" type="system">
    <hardware>
      <plugin>sts_hardware_interface/STSHardwareInterface</plugin>
      <param name="serial_port">$(arg serial_port)</param>
      <param name="baud_rate">${baud_rate}</param>
      <param name="communication_timeout_ms">100</param>
      <param name="use_sync_write">$(arg use_sync_write)</param>
      <param name="enable_mock_mode">$(arg use_mock)</param>
      <param name="max_velocity_steps">${sts_max_velocity_steps}</param>
      <param name="reset_states_on_activate">true</param>
    </hardware>

    <!-- Pan axis: rotates the payload around Z (Motor ID ${pan_motor_id}) -->
    <joint name="pan_joint">
      <param name="motor_id">${pan_motor_id}</param>
      <param name="operating_mode">${pantilt_operating_mode}</param>
      <param name="min_position">${pan_joint_lower}</param>
      <param name="max_position">${pan_joint_upper}</param>
      <param name="max_velocity">${max_velocity_rads}</param>
      <param name="position_center_steps">2048</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="acceleration"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>

    <!-- Tilt axis: rotates the payload around Y (Motor ID ${tilt_motor_id}) -->
    <joint name="tilt_joint">
      <param name="motor_id">${tilt_motor_id}</param>
      <param name="operating_mode">${pantilt_operating_mode}</param>
      <param name="min_position">${tilt_joint_lower}</param>
      <param name="max_position">${tilt_joint_upper}</param>
      <param name="max_velocity">${max_velocity_rads}</param>
      <param name="position_center_steps">2048</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="acceleration"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>

  </ros2_control>

</robot>
