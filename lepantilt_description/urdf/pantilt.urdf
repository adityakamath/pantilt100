    <child link="oak_link"/>
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="-0.03435 -0.01 0"/>
  </joint>
  <!-- IMU frame -->
  <link name="oak_imu_frame"/>
  <joint name="oak_imu_frame_joint" type="fixed">
    <parent link="oak_link"/>
    <child link="oak_imu_frame"/>
    <origin rpy="3.141592653589793 1.5707963267948966 0" xyz="-0.008 -0.037945 -0.00079"/>
  </joint>
  <!-- Device mesh with custom color -->
  <link name="oak_link_model_origin">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
