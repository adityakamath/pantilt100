    <child link="tilt_link"/>
    <origin rpy="-1.5707963267948966 1.5707963267948966 0" xyz="0.0306 0 0.1025"/>
    <axis xyz="0 0 -1"/>
    <limit effort="2.942" lower="-1.5707963267948966" upper="1.5707963267948966" velocity="1e6"/>
  </joint>
  <!--
	  Custom OAK-D-S2 camera macro for lepantilt only.
