<robot name="lepantilt">
  <!-- N⋅m (30 kgf⋅cm for STS3215) -->
  <!-- ROS 2 CONTROL -->
  <ros2_control name="lepantilt_control" type="system">
    <hardware>
      <plugin>sts_hardware_interface/STSHardwareInterface</plugin>
      <param name="serial_port">/dev/ttySERVO</param>
      <param name="baud_rate">1000000</param>
      <param name="communication_timeout_ms">100</param>
      <param name="use_sync_write">true</param>
      <param name="enable_mock_mode">false</param>
      <param name="max_velocity_steps">3400</param>
      <param name="reset_states_on_activate">true</param>
    </hardware>
    <!-- Pan axis: rotates the payload around Z (Motor ID ${pan_motor_id}) -->
    <joint name="pan_joint">
      <param name="motor_id">1</param>
      <param name="operating_mode">0</param>
      <param name="min_position">-1.5707963267948966</param>
      <param name="max_position">1.5707963267948966</param>
      <param name="max_velocity">2.60776733940559</param>
      <param name="position_center_steps">2048</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
    <!-- Tilt axis: rotates the payload around Y (Motor ID ${tilt_motor_id}) -->
    <joint name="tilt_joint">
      <param name="motor_id">2</param>
      <param name="operating_mode">0</param>
      <param name="min_position">-1.5707963267948966</param>
      <param name="max_position">1.5707963267948966</param>
      <param name="max_velocity">2.60776733940559</param>
      <param name="position_center_steps">2646</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="temperature"/>
      <state_interface name="current"/>
      <state_interface name="is_moving"/>
    </joint>
  </ros2_control>
  <!-- Standalone pantilt module instantiation -->
  <link name="base_footprint"/>
  <!-- Material definitions (referenced by links below) -->
  <material name="light_grey">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>
  <material name="charcoal">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <!-- Mount pantilt_base_link to parent platform at specified origin -->
  <joint name="pantilt_mount_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="pantilt_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <!-- Pan-tilt base link (was "base_link" in standalone URDF) -->
  <link name="pantilt_base_link">
    <inertial>
      <mass value="1.0"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
