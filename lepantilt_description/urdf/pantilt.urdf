  <!-- Pan joint (revolute) -->
  <joint name="pan_joint" type="revolute">
    <parent link="pantilt_base_link"/>
    <child link="pan_link"/>
    <origin rpy="0 0 0" xyz="0.0452 0 0.0165"/>
    <axis xyz="0 0 1"/>
    <limit effort="2.942" lower="-1.5707963267948966" upper="1.5707963267948966" velocity="1e6"/>
  </joint>
  <!-- Tilt joint (revolute) -->
  <joint name="tilt_joint" type="revolute">
