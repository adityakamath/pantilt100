<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Color properties (RGBA) -->
  <xacro:property name="light_grey_rgba" value="0.8 0.8 0.8 1.0"/>
  <xacro:property name="charcoal_rgba" value="0.15 0.15 0.15 1.0"/>
  <xacro:property name="charcoal_rgb" value="0.15"/>

  <!-- Pantilt base visual compensation / mount rotation (rad) -->
  <xacro:property name="pantilt_offset_rz" value="${pi/2}"/>

  <!-- Pan link visual compensation (rad) -->
  <xacro:property name="pan_offset_rx" value="${pi/2}"/>
  <xacro:property name="pan_offset_rz" value="${pi/2}"/>

  <!-- Pan joint origin (in reoriented base_link frame) -->
  <xacro:property name="pan_joint_x" value="0.0452"/>
  <xacro:property name="pan_joint_z" value="0.0165"/>

  <!-- Tilt joint origin (in pan_link frame — same as SO100 shoulder_lift) -->
  <xacro:property name="tilt_joint_x" value="0.0306"/>
  <xacro:property name="tilt_joint_z" value="0.1025"/>

  <!-- Tilt joint frame rotation (makes Z the tilt axis, +θ = forward) -->
  <xacro:property name="tilt_joint_rx" value="${-pi/2}"/>
  <xacro:property name="tilt_joint_ry" value="${pi/2}"/>

  <!-- Tilt link visual compensation — counter-rotate joint frame + place mesh at base origin -->
  <xacro:property name="tilt_offset_rx" value="${pi/2}"/>
  <xacro:property name="tilt_offset_ry" value="${-pi/2}"/>
  <xacro:property name="tilt_visual_x" value="${pan_joint_z + tilt_joint_z}"/>
  <xacro:property name="tilt_visual_y" value="${pan_joint_x + tilt_joint_x}"/>
  <xacro:property name="tilt_visual_z" value="-0.0002"/>

  <!-- OAK-D-S2 camera mount offset (in tilt_link frame) -->
  <xacro:property name="oak_pos_x" value="-0.03435"/>
  <xacro:property name="oak_pos_y" value="-0.01"/>

  <!-- OAK-D-S2 camera mount orientation (in tilt_link frame) -->
  <xacro:property name="oak_roll" value="${-pi/2}"/>
  <xacro:property name="oak_yaw"  value="${-pi/2}"/>

  <!-- OAK-D-S2 IMU offset (relative to oak frame) -->
  <xacro:property name="oak_imu_x" value="-0.008"/>
  <xacro:property name="oak_imu_y" value="-0.037945"/>
  <xacro:property name="oak_imu_z" value="-0.00079"/>
  <xacro:property name="oak_imu_r" value="${pi}"/>
  <xacro:property name="oak_imu_p" value="${pi/2}"/>

</robot>
